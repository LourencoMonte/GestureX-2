<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top bar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="24dp">
            <ImageButton android:id="@+id/btnVoltar" android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_circle_surface" android:src="@drawable/ic_arrow_back"
                android:contentDescription="Voltar"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Editar Gesto" android:textColor="@color/text_primary"
                android:textSize="18sp" android:textStyle="bold" android:layout_marginStart="12dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeletar" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Deletar" android:textColor="@color/error" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Gesture type card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp" app:strokeWidth="1dp" app:strokeColor="@color/border">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="GESTO DETECTADO" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/textTipoGesto" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/primary"
                    android:textSize="16sp" android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Name field -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" android:hint="Nome do gesto"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/border" app:hintTextColor="@color/text_secondary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editNome" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="@color/text_primary"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Action label -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ESCOLHER AÇÃO" android:textColor="@color/text_secondary"
            android:textSize="11sp" android:letterSpacing="0.1" android:layout_marginBottom="12dp"/>

        <!-- Action cards grid -->
        <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="2" android:rowCount="2" android:layout_marginBottom="16dp"
            android:useDefaultMargins="true">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAcaoApp" android:layout_width="0dp" android:layout_height="80dp"
                android:layout_columnWeight="1" app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="14dp" app:strokeWidth="1dp" app:strokeColor="@color/border">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="8dp">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_apps" app:tint="@color/text_secondary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Abrir app" android:textColor="@color/text_secondary"
                        android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAcaoLanterna" android:layout_width="0dp" android:layout_height="80dp"
                android:layout_columnWeight="1" app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="14dp" app:strokeWidth="1dp" app:strokeColor="@color/border">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="8dp">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_flashlight_on" app:tint="@color/text_secondary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Lanterna" android:textColor="@color/text_secondary"
                        android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAcaoSilenciar" android:layout_width="0dp" android:layout_height="80dp"
                android:layout_columnWeight="1" app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="14dp" app:strokeWidth="1dp" app:strokeColor="@color/border">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="8dp">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_volume_off" app:tint="@color/text_secondary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Silenciar" android:textColor="@color/text_secondary"
                        android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAcaoLigar" android:layout_width="0dp" android:layout_height="80dp"
                android:layout_columnWeight="1" app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="14dp" app:strokeWidth="1dp" app:strokeColor="@color/border">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="8dp">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_call" app:tint="@color/text_secondary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ligar para" android:textColor="@color/text_secondary"
                        android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- App picker section -->
        <LinearLayout android:id="@+id/layoutEscolherApp" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:visibility="gone" android:layout_marginBottom="12dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEscolherApp" android:layout_width="match_parent"
                android:layout_height="48dp" android:text="Escolher app instalado"
                android:textColor="@color/primary" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/primary"/>
            <TextView android:id="@+id/textAppSelecionado" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/success"
                android:textSize="13sp" android:layout_marginTop="6dp" android:visibility="gone"/>
        </LinearLayout>

        <!-- Contact picker section -->
        <LinearLayout android:id="@+id/layoutEscolherContato" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:visibility="gone" android:layout_marginBottom="12dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEscolherContato" android:layout_width="match_parent"
                android:layout_height="48dp" android:text="Escolher contato"
                android:textColor="@color/primary" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/primary"/>
            <TextView android:id="@+id/textContatoSelecionado" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/success"
                android:textSize="13sp" android:layout_marginTop="6dp" android:visibility="gone"/>
        </LinearLayout>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalvar" android:layout_width="match_parent"
            android:layout_height="56dp" android:text="Salvar Gesto"
            android:textColor="@color/white" android:textSize="15sp"
            android:backgroundTint="@color/primary" app:cornerRadius="14dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>
