<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/btnVoltar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_surface"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="Voltar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textTitleRecord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gravar Gesto"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/btnVoltar"
        app:layout_constraintBottom_toBottomOf="@id/btnVoltar"
        app:layout_constraintStart_toEndOf="@id/btnVoltar"
        android:layout_marginStart="12dp"/>

    <!-- Sensor card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSensor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="20dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border"
        app:layout_constraintTop_toBottomOf="@id/btnVoltar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACELERÔMETRO (m/s²)"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <!-- X -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                    android:text="X" android:textColor="@color/primary" android:textStyle="bold" android:textSize="12sp"/>
                <ProgressBar android:id="@+id/progressX" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1"
                    android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
                    android:max="100" android:progress="50" android:progressTint="@color/primary"/>
                <TextView android:id="@+id/textEixoX" android:layout_width="60dp" android:layout_height="wrap_content"
                    android:text="X: 0.0" android:textColor="@color/text_secondary" android:textSize="11sp"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- Y -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                    android:text="Y" android:textColor="@color/gesture_teal" android:textStyle="bold" android:textSize="12sp"/>
                <ProgressBar android:id="@+id/progressY" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1"
                    android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
                    android:max="100" android:progress="50" android:progressTint="@color/gesture_teal"/>
                <TextView android:id="@+id/textEixoY" android:layout_width="60dp" android:layout_height="wrap_content"
                    android:text="Y: 0.0" android:textColor="@color/text_secondary" android:textSize="11sp"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- Z -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                    android:text="Z" android:textColor="@color/gesture_amber" android:textStyle="bold" android:textSize="12sp"/>
                <ProgressBar android:id="@+id/progressZ" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1"
                    android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
                    android:max="100" android:progress="50" android:progressTint="@color/gesture_amber"/>
                <TextView android:id="@+id/textEixoZ" android:layout_width="60dp" android:layout_height="wrap_content"
                    android:text="Z: 0.0" android:textColor="@color/text_secondary" android:textSize="11sp"
                    android:gravity="end"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/textStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Toque em Iniciar e faça o gesto"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cardSensor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGravar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Iniciar Gravação"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:backgroundTint="@color/error"
        app:cornerRadius="14dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
